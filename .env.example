# =============================================================================
# TMJ Editorial Intelligence - Environment Variables (Milestone 3)
# =============================================================================
# Copy the backend and frontend sections into their respective files:
#   backend/.env
#   frontend/.env.local
# Never commit real secrets to git.
# =============================================================================

# --- Backend (backend/.env) ---

ENVIRONMENT=development
LOG_LEVEL=INFO

# Supabase -> Project Settings -> Database -> Connection string (URI)
# Use the "Session pooler" or "Direct connection" string for local dev.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase -> Project Settings -> API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Shared secret for local pipeline endpoints.
# Send this value as the X-API-Key header when triggering ingestion.
API_SECRET_KEY=replace-with-a-long-random-local-secret

# Maximum feed entries to process per source in one local ingestion run
INGESTION_MAX_ARTICLES_PER_SOURCE=50

# OpenAI enrichment, introduced in Milestone 3.
# Keep ENRICHMENT_BATCH_SIZE small while testing locally.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
ENRICHMENT_BATCH_SIZE=3

# --- Frontend (frontend/.env.local) ---

NEXT_PUBLIC_API_URL=http://localhost:8000
